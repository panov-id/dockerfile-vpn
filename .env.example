# Copy to `.env` on the VPS only — never commit `.env`.
# Unique per environment on the same host (production / UAT / …).

# Docker Compose project name — isolates networks and containers on one VPS.
COMPOSE_PROJECT_NAME=vpn-production

# Public hostname or IP clients connect to (must match your VPN endpoint).
WIREGUARD_SERVER_PUBLIC_HOST=vpn.example.com

# Host UDP port (must be free on the VPS and allowed in firewalls).
WIREGUARD_SERVER_PORT=51820

# linuxserver/wireguard: comma-separated peer names or a count (see image docs).
WIREGUARD_INITIAL_PEER_COUNT=1

# Tunnel subnet for this stack only — use a different /24 per environment.
WIREGUARD_INTERNAL_SUBNET=10.13.13.0

# Routes pushed to clients (default: send all IPv4 via tunnel).
WIREGUARD_ALLOWED_IPS=0.0.0.0/0

WIREGUARD_TIME_ZONE=Etc/UTC
WIREGUARD_CONTAINER_USER_ID=1000
WIREGUARD_CONTAINER_GROUP_ID=1000

WIREGUARD_LOG_CONFIGURATIONS=true

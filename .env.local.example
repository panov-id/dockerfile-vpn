# Copy to `.env.local` on your machine — never commit `.env.local`.
# Used with: docker compose -f docker-compose.yml -f docker-compose.local.yml --env-file .env.local …

COMPOSE_PROJECT_NAME=vpn-local

# Host directory mounted as /config inside the container (unique per parallel stack).
LOCAL_WIREGUARD_CONFIG_DIRECTORY=./config.local

# Endpoint WireGuard clients use:
# - Same machine (wg client on host): 127.0.0.1 is OK with published UDP port.
# - Phone / another PC on LAN: put your machine's LAN IP here (e.g. 192.168.1.50).
WIREGUARD_SERVER_PUBLIC_HOST=127.0.0.1

# Pick a free UDP port on your laptop (avoid clashing with a VPS stack if you tunnel).
WIREGUARD_SERVER_PORT=51830

WIREGUARD_INITIAL_PEER_COUNT=1

# Different /24 than production examples so routes stay mentally separate.
WIREGUARD_INTERNAL_SUBNET=10.14.14.0

WIREGUARD_ALLOWED_IPS=0.0.0.0/0
WIREGUARD_TIME_ZONE=Etc/UTC
WIREGUARD_CONTAINER_USER_ID=1000
WIREGUARD_CONTAINER_GROUP_ID=1000
WIREGUARD_LOG_CONFIGURATIONS=true

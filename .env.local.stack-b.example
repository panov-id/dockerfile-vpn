# Second local stack — copy to `.env.local.stack-b` (gitignored pattern matches .env.local.*).
# Run alongside `.env.local` to prove two UDP ports / two subnets / two config dirs work.

COMPOSE_PROJECT_NAME=vpn-local-b
LOCAL_WIREGUARD_CONFIG_DIRECTORY=./config.local.stack-b

WIREGUARD_SERVER_PUBLIC_HOST=127.0.0.1
WIREGUARD_SERVER_PORT=51831

WIREGUARD_INITIAL_PEER_COUNT=1
WIREGUARD_INTERNAL_SUBNET=10.15.15.0

WIREGUARD_ALLOWED_IPS=0.0.0.0/0
WIREGUARD_TIME_ZONE=Etc/UTC
WIREGUARD_CONTAINER_USER_ID=1000
WIREGUARD_CONTAINER_GROUP_ID=1000
WIREGUARD_LOG_CONFIGURATIONS=true

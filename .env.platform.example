# =============================================================================
# Platform setup — copy to .env.platform and edit (gitignored)
#
#   cp .env.platform.example .env.platform
#   ./scripts/launchpad-run.sh
#
# Each GitHub environment has its OWN block (no global SSH_HOST fallback).
# Same VPS for all stands: repeat the same IP/paths in every block.
# Different VPS per environment: set different SSH_HOST per block.
#
# Teardown (VPS only, keeps GitHub as-is):
#   TEARDOWN_CONFIRM=yes ./scripts/teardown-platform-run.sh
# =============================================================================

# --- GLOBAL (repository + GitHub API) ----------------------------------------

GITHUB_TOKEN=REPLACE_ME_github_pat

# Comma-separated GitHub Environments to configure (default: all five)
PLATFORM_ENVIRONMENTS=production,uat,dev,test,mr-preview

# --- production (GitHub Environment: production) ------------------------------

PRODUCTION_SSH_HOST=REPLACE_ME_VPS_IP
PRODUCTION_SSH_USER=root
PRODUCTION_SSH_PRIVATE_KEY_HOST_PATH=/home/you/.ssh/vpn_deploy_ed25519
PRODUCTION_STANDS_ROOT=/srv/vpn
PRODUCTION_STANDS_TOOLING_DIRECTORY=/srv/vpn/_tooling
PRODUCTION_STAND_DNS_ZONE=vpn.example.com
PRODUCTION_BOOTSTRAP_STANDS=production

# --- uat (GitHub Environment: uat) --------------------------------------------

UAT_SSH_HOST=REPLACE_ME_VPS_IP
UAT_SSH_USER=root
UAT_SSH_PRIVATE_KEY_HOST_PATH=/home/you/.ssh/vpn_deploy_ed25519
UAT_STANDS_ROOT=/srv/vpn
UAT_STANDS_TOOLING_DIRECTORY=/srv/vpn/_tooling
UAT_STAND_DNS_ZONE=vpn.example.com
UAT_BOOTSTRAP_STANDS=uat

# --- dev (GitHub Environment: dev) --------------------------------------------

DEV_SSH_HOST=REPLACE_ME_VPS_IP
DEV_SSH_USER=root
DEV_SSH_PRIVATE_KEY_HOST_PATH=/home/you/.ssh/vpn_deploy_ed25519
DEV_STANDS_ROOT=/srv/vpn
DEV_STANDS_TOOLING_DIRECTORY=/srv/vpn/_tooling
DEV_STAND_DNS_ZONE=vpn.example.com
DEV_BOOTSTRAP_STANDS=dev

# --- test (GitHub Environment: test) ------------------------------------------

TEST_SSH_HOST=REPLACE_ME_VPS_IP
TEST_SSH_USER=root
TEST_SSH_PRIVATE_KEY_HOST_PATH=/home/you/.ssh/vpn_deploy_ed25519
TEST_STANDS_ROOT=/srv/vpn
TEST_STANDS_TOOLING_DIRECTORY=/srv/vpn/_tooling
TEST_STAND_DNS_ZONE=vpn.example.com
TEST_BOOTSTRAP_STANDS=test

# --- mr-preview (GitHub Environment: mr-preview) ------------------------------
# MR stands are created by CI; leave BOOTSTRAP_STANDS empty unless you want
# a one-off MR directory at launchpad time.

MR_PREVIEW_SSH_HOST=REPLACE_ME_VPS_IP
MR_PREVIEW_SSH_USER=root
MR_PREVIEW_SSH_PRIVATE_KEY_HOST_PATH=/home/you/.ssh/vpn_deploy_ed25519
MR_PREVIEW_STANDS_ROOT=/srv/vpn
MR_PREVIEW_STANDS_TOOLING_DIRECTORY=/srv/vpn/_tooling
MR_PREVIEW_STAND_DNS_ZONE=vpn.example.com
MR_PREVIEW_BOOTSTRAP_STANDS=

# --- EXAMPLE: production on another VPS (uncomment and edit) -------------------
# PRODUCTION_SSH_HOST=203.0.113.10
# PRODUCTION_STANDS_ROOT=/srv/vpn
# DEV_SSH_HOST=203.0.113.20
# DEV_STANDS_ROOT=/srv/vpn
# MR_PREVIEW_SSH_HOST=203.0.113.20
# MR_PREVIEW_STANDS_ROOT=/srv/vpn

# --- GITHUB (defaults = github.com) -------------------------------------------

# GITHUB_REPOSITORY_SLUG=panov-id/dockerfile-vpn
# GIT_REMOTE_URL=https://github.com/panov-id/dockerfile-vpn.git

# --- LAUNCHPAD STEPS ----------------------------------------------------------

# SETUP_GITHUB=true
# SETUP_GITHUB_STRICT=true
# SETUP_CREATE_BRANCHES=true
# SETUP_VPS=true
# SETUP_VPS_INSTALL_DOCKER=true
# SETUP_LOCAL_COMPOSE_CHECK=false

# --- TEARDOWN (teardown-platform-run.sh) --------------------------------------

# TEARDOWN_ENVIRONMENTS=production,uat,dev,test,mr-preview
# TEARDOWN_REMOVE_TOOLING=true

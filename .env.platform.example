# Copy once:  cp .env.platform.example .env.platform
# Run setup (no gh/git on host):  ./scripts/launchpad-run.sh
# File .env.platform is gitignored.

# --- REQUIRED ---
SSH_HOST=203.0.113.10
SSH_USER=deploy

# Absolute path to deploy private key ON YOUR MACHINE (mounted into launchpad container)
LAUNCHPAD_SSH_PRIVATE_KEY_HOST_PATH=/home/you/.ssh/vpn_deploy_ed25519

# GitHub PAT: repo + Actions (secrets/variables). Create: GitHub → Settings → Developer settings → PAT
GITHUB_TOKEN=ghp_replace_me

# DNS zone for stands (MR → mr-42.vpn.example.com, dev → dev.vpn.example.com)
STAND_DNS_ZONE=vpn.example.com

# --- OPTIONAL ---
# GITHUB_REPOSITORY_SLUG=panov-id/dockerfile-vpn
# GIT_REMOTE_URL=git@github.com:panov-id/dockerfile-vpn.git
# STANDS_ROOT=/srv/vpn
# STANDS_TOOLING_DIRECTORY=/srv/vpn/_tooling
# VPS_STANDS_TO_BOOTSTRAP=dev,test,uat,production

# Host-only fallback if you run ./scripts/setup-platform.sh without launchpad:
# SSH_PRIVATE_KEY_FILE=/home/you/.ssh/vpn_deploy_ed25519

# SETUP_GITHUB=true
# SETUP_VPS=true
# SETUP_CREATE_BRANCHES=true
# SETUP_LOCAL_COMPOSE_CHECK=false

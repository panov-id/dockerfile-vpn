# =============================================================================
# Platform setup — copy to .env.platform and edit (gitignored)
#
#   cp .env.platform.example .env.platform
#   ./scripts/launchpad-run.sh
#
# gh exists ONLY inside the launchpad container — not on your laptop.
# =============================================================================
#
# CHECKLIST — replace every REPLACE_ME / example value before first run:
#
#   [ ] SSH_HOST              → real VPS IP or hostname
#   [ ] SSH_USER              → deploy user on VPS (key in authorized_keys)
#   [ ] LAUNCHPAD_SSH_...     → deploy private key, NO passphrase (docs/deploy-ssh-key.md)
#   [ ] GITHUB_TOKEN          → PAT from https://github.com/settings/tokens
#   [ ] STAND_DNS_ZONE        → your DNS zone (wildcard *.zone → SSH_HOST)
#
# Repo is on github.com — leave GH_HOST unset unless you use GitHub Enterprise Server.
#
# After a successful run you should see on GitHub:
#   • Environments: production, uat, dev, test, mr-preview
#   • Branches: dev, test (same tip as main, if missing before)
# On VPS under STANDS_ROOT: dev, test, uat, production stands
#
# Re-run launchpad anytime after editing this file (safe to repeat).
# =============================================================================

# --- REQUIRED (launchpad refuses to start without these) ---------------------

# VPS: where WireGuard stands are deployed
SSH_HOST=REPLACE_ME_VPS_IP
SSH_USER=deploy

# Deploy private key on YOUR laptop — NO passphrase (launchpad cannot ask for it)
# Must match public key in SSH_USER's ~/.ssh/authorized_keys on VPS
#   ssh-keygen -t ed25519 -f ~/.ssh/vpn_deploy_ed25519 -N '' -C 'dockerfile-vpn-deploy'
#   ssh-copy-id -i ~/.ssh/vpn_deploy_ed25519.pub root@YOUR_VPS
LAUNCHPAD_SSH_PRIVATE_KEY_HOST_PATH=/home/you/.ssh/vpn_deploy_ed25519

# GitHub PAT from https://github.com/settings/tokens
# Classic: scopes repo + workflow. Fine-grained: this repo, Contents R/W, Actions, Secrets, Admin
GITHUB_TOKEN=REPLACE_ME_github_pat

# DNS zone for stands — NOT a full URL, no https://
STAND_DNS_ZONE=vpn.example.com

# --- GITHUB (defaults = github.com; do not uncomment unless real GHE) --------

# GITHUB_REPOSITORY_SLUG=panov-id/dockerfile-vpn
# HTTPS clone URL used on VPS / in Actions variables (launchpad sets this automatically):
# GIT_REMOTE_URL=https://github.com/panov-id/dockerfile-vpn.git
#
# Only for corporate GitHub Enterprise (real hostname, opens in browser):
# GH_HOST=github.mycompany.com
# GITHUB_API_URL=https://github.mycompany.com/api/v3/

# --- VPS LAYOUT (defaults are fine for most setups) --------------------------

# STANDS_ROOT=/srv/vpn
# STANDS_TOOLING_DIRECTORY=/srv/vpn/_tooling
# VPS_STANDS_TO_BOOTSTRAP=dev,test,uat,production

# --- WHAT LAUNCHPAD RUNS -----------------------------------------------------

# SETUP_GITHUB=true
# SETUP_GITHUB_STRICT=true          # false = continue to VPS even if Environments API fails
# SETUP_CREATE_BRANCHES=true
# SETUP_VPS=true
# SETUP_VPS_INSTALL_DOCKER=true   # apt install docker.io + compose plugin on Debian/Ubuntu before stands
# SETUP_LOCAL_COMPOSE_CHECK=false

# --- HOST-ONLY FALLBACK (not for launchpad-run.sh) ---------------------------

# SSH_PRIVATE_KEY_FILE=/home/you/.ssh/vpn_deploy_ed25519
